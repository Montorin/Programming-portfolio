---
import type { JournalEntry } from "../data/site";

interface Props {
  entries: JournalEntry[];
}

const { entries } = Astro.props;
---

<ol class="timeline">
  {entries.map((entry) => (
    <li>
      <span class="timeline-date">{entry.date}</span>
      <div>
        <h3>{entry.title}</h3>
        <p>{entry.body}</p>
        <div class="tag-row">
          {entry.tags.map((tag) => <span>{tag}</span>)}
        </div>
      </div>
    </li>
  ))}
</ol>
